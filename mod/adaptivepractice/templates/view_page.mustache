{{!
    View page template for Adaptive Practice
}}
<div class="mod_adaptivepractice_view">

    {{#intro}}
    <div class="mod_adaptivepractice_intro mb-4">
        {{{intro}}}
    </div>
    {{/intro}}

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px; overflow: hidden;">
        <div class="card-header bg-white border-0 pt-4 text-center">
            <h2 class="font-weight-bold" style="color: #1e293b;">{{#str}}current_competency, mod_adaptivepractice, {{competency}}{{/str}}</h2>
        </div>
        <div class="card-body px-4 pb-4">
            <div class="row text-center mb-4">
                <div class="col-4">
                    <div class="p-3 rounded" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                        <div style="font-size: 1.5rem; font-weight: 800; color: #0FB9B1">{{counts.easy}}</div>
                        <div class="small text-muted font-weight-bold text-uppercase">Easy</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                        <div style="font-size: 1.5rem; font-weight: 800; color: #FF8A00">{{counts.medium}}</div>
                        <div class="small text-muted font-weight-bold text-uppercase">Medium</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                        <div style="font-size: 1.5rem; font-weight: 800; color: #6C5CE7">{{counts.hard}}</div>
                        <div class="small text-muted font-weight-bold text-uppercase">Hard</div>
                    </div>
                </div>
            </div>

            <p class="text-center text-muted mb-0">Session Length: <strong>{{questionsperattempt}} questions</strong></p>
            <p class="text-center text-muted mt-2">Mode: <span class="badge badge-info px-3 py-2">{{session_mode_label}}</span></p>
            <p class="text-center text-muted mt-2">Recommended: <span class="badge badge-primary px-3 py-2">{{difficulty}}</span></p>
        </div>
    </div>

    {{#attemptserror}}
    <div class="alert alert-danger text-center">
        {{attemptserror}}
    </div>
    {{/attemptserror}}

    <div class="quizattempt text-center mt-4">
        {{#hasquestions}}
            {{#canstart}}
            <form method="get" action="{{attempturl}}">
                <input type="hidden" name="id" value="{{cmid}}">
                <div class="d-inline-block mb-3 mr-2">
                    <select name="force_difficulty" class="form-control custom-select shadow-sm" style="height: 45px; border-radius: 25px;">
                        <option value="mixed">🚀 Full Practice (All Levels)</option>
                        <option value="easy">🟢 Easy Level Only</option>
                        <option value="medium">🟡 Medium Level Only</option>
                        <option value="hard">🔴 Hard Level Only</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary btn-lg shadow-sm px-5 py-2" style="border-radius: 50px; font-size: 1.1rem; vertical-align: top;">
                    <i class="fa {{starticon}} mr-2"></i> {{startlabel}}
                </button>
            </form>
            {{/canstart}}
        {{/hasquestions}}
        {{^hasquestions}}
            {{#canmanage}}
            <a href="{{questionsurl}}" class="btn btn-primary">{{#str}}questions, mod_adaptivepractice{{/str}}</a>
            {{/canmanage}}
        {{/hasquestions}}
    </div>

    {{#hasattempts}}
    <div class="card mt-5 mb-4 border-0 shadow-sm" style="border-radius: 12px; background-color: #f1f5f9; border-left: 5px solid #007bff !important;">
        <div class="card-body p-3 d-flex justify-content-between align-items-center">
            <div>
                <span class="text-muted mr-2">Grading method:</span>
                <span class="badge badge-secondary px-3 py-2" style="font-size: 0.9rem;">{{grademethod}}</span>
            </div>
            <div>
                <span class="h5 mb-0 mr-2">Final grade:</span>
                <span class="h4 mb-0 text-primary font-weight-bold">{{finalgrade}}</span>
            </div>
        </div>
    </div>

    <h4 class="mb-3">Your Previous Sessions</h4>
    <div class="table-responsive">
        <table class="table table-striped table-hover mt-3">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Difficulty</th>
                    <th>Score</th>
                    <th>Badge</th>
                    <th>Review</th>
                </tr>
            </thead>
            <tbody>
                {{#previousattempts}}
                <tr>
                    <td>{{date}}</td>
                    <td>{{difficulty}}</td>
                    <td><span class="{{scoreclass}}">{{score}}</span></td>
                    <td>
                        {{#has_badge}}
                        <div class="d-flex align-items-center" style="gap: 6px; white-space: nowrap;">
                            <img src="{{badge_image_url}}" alt="{{badge_label}}"
                                 title="{{badge_label}}"
                                 style="width: 30px; height: 30px; object-fit: contain;">
                            <span style="font-size: 0.82rem; font-weight: 700; color: #555;">{{badge_label}}</span>
                        </div>
                        {{/has_badge}}
                        {{^has_badge}}
                        <span class="text-muted" style="font-size: 0.85rem;">—</span>
                        {{/has_badge}}
                    </td>
                    <td><a href="{{reviewurl}}" class="btn btn-sm btn-outline-primary">{{reviewlabel}}</a></td>
                </tr>
                {{/previousattempts}}
            </tbody>
        </table>
    </div>
    {{/hasattempts}}
</div>
