{{!
    Attempt summary template for Adaptive Practice
}}
<div class="mod_adaptivepractice_summary">
    <div class="tertiary-navigation mb-4">
        <a href="{{backurl}}" class="btn btn-secondary btn-sm">← {{#str}}back, mod_adaptivepractice{{/str}}</a>
    </div>

    <h2 class="mb-4 text-center">Session Summary</h2>

    {{#score_below_70}}
    <div class="ap-motivational-banner alert d-flex align-items-center justify-content-between flex-wrap mb-4"
         style="background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
                border-left: 5px solid #f39c12;
                border-radius: 10px;
                padding: 16px 20px;
                max-width: 800px;
                margin: 0 auto 24px auto;
                box-shadow: 0 2px 12px rgba(243,156,18,0.18);">
        <div class="d-flex align-items-center" style="gap: 12px;">
            <span style="font-size: 2rem;">💪</span>
            <div>
                <div style="font-weight: 700; font-size: 1.05rem; color: #856404;">Keep Going!</div>
                <div style="color: #856404; font-size: 0.95rem;">
                    Great job! Improve your score. Continue practicing.
                </div>
            </div>
        </div>
        <a href="{{continue_url}}"
           class="btn btn-warning font-weight-bold mt-2 mt-md-0"
           style="border-radius: 8px; padding: 8px 22px; font-size: 0.97rem; white-space: nowrap; box-shadow: 0 2px 8px rgba(243,156,18,0.3);">
            🔄 Continue Practice
        </a>
    </div>
    {{/score_below_70}}

    {{#has_badge}}
    <div class="ap-badge-banner d-flex align-items-center justify-content-center mb-4"
         style="max-width: 800px; margin: 0 auto 20px auto;
                background: linear-gradient(135deg, #fffdf0 0%, #fff8e1 100%);
                border-radius: 14px;
                padding: 18px 28px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.10);
                gap: 20px;
                flex-wrap: wrap;
                border: 2px solid {{badge_color}};">
        <img src="{{badge_image_url}}" alt="{{badge_name}}"
             style="width: 72px; height: 72px; object-fit: contain; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.2));">
        <div>
            <div style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #888; font-weight: 600;">
                Achievement Unlocked
            </div>
            <div style="font-size: 1.4rem; font-weight: 800; color: #1a1a2e; margin-top: 2px;">
                {{badge_label}}
            </div>
            <div style="font-size: 0.9rem; color: #555; margin-top: 4px;">
                Awarded for scoring <strong>{{score}}%</strong> — well done!
            </div>
        </div>
    </div>
    {{/has_badge}}

    <div class="card shadow-sm border-0 mb-5" style="border-radius: 12px; max-width: 800px; margin: 0 auto;">
        <div class="card-body p-4">
            <div class="row text-center">
                <div class="col-md-4 mb-3 mb-md-0">
                    {{{user.picture}}}
                    <div class="font-weight-bold mt-2">{{user.fullname}}</div>
                    <div class="small text-muted">{{user.date}}</div>
                </div>

                <div class="col-md-4 mb-3 mb-md-0">
                    <div class="text-muted small text-uppercase font-weight-bold">Score</div>
                    <div class="h1 font-weight-bold {{scorecolor}}" style="margin: 5px 0;">{{score}}%</div>
                    <span class="badge badge-light">Difficulty: {{difficulty}}</span>
                    {{#has_badge}}
                    <div class="mt-2">
                        <img src="{{badge_image_url}}" alt="{{badge_name}}"
                             title="{{badge_label}}"
                             style="width: 36px; height: 36px; object-fit: contain; vertical-align: middle;">
                        <span style="font-size: 0.85rem; font-weight: 700; color: #555; vertical-align: middle; margin-left: 4px;">{{badge_label}}</span>
                    </div>
                    {{/has_badge}}
                </div>

                <div class="col-md-4">
                    <div class="text-muted small text-uppercase font-weight-bold">Status</div>
                    <div class="badge {{statusclass}} px-3 py-2 mt-2" style="font-size: 1rem;">{{status}}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="ap-review-questions" style="max-width: 850px; margin: 0 auto;">
        <h4 class="mb-4">Question Breakdown</h4>

        {{#questions}}
        <div class="card mb-4 shadow-sm border-0" style="border-radius: 10px; overflow: hidden;">
            <div class="card-header bg-light d-flex justify-content-between align-items-center py-2">
                <span class="font-weight-bold">Question {{slot}}</span>
                <span class="badge {{badgeclass}}">{{mark}} / {{max}}</span>
            </div>
            <div class="card-body">
                {{{content}}}
            </div>
        </div>
        {{/questions}}
    </div>
</div>

{{#score_is_100}}
<!-- Score 100% Achievement Popup Modal -->
<div id="ap-achievement-modal-overlay"
     style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.55);
            z-index: 9999; align-items: center; justify-content: center; backdrop-filter: blur(3px);">
    <div style="background: #fff; border-radius: 18px; max-width: 460px; width: 90%; padding: 36px 30px;
                box-shadow: 0 20px 60px rgba(0,0,0,0.3); text-align: center; position: relative;
                animation: apPopIn 0.4s cubic-bezier(.17,.67,.45,1.3);">
        <button onclick="document.getElementById('ap-achievement-modal-overlay').style.display='none';"
                style="position:absolute;top:12px;right:16px;background:none;border:none;font-size:1.4rem;
                       cursor:pointer;color:#888;line-height:1;" aria-label="Close">✕</button>

        <div style="font-size: 3.5rem; line-height: 1.2; margin-bottom: 10px;">🎊</div>

        {{#has_badge}}
        <div style="margin-bottom: 16px;">
            <img src="{{badge_image_url}}" alt="{{badge_name}}"
                 style="width: 90px; height: 90px; object-fit: contain;
                        filter: drop-shadow(0 6px 16px rgba(0,0,0,0.25));
                        animation: apBadgeBounce 0.8s ease 0.3s both;">
            <div style="font-size: 1.15rem; font-weight: 800; margin-top: 8px; color: #1a1a2e;">
                {{badge_label}}
            </div>
        </div>
        {{/has_badge}}

        <h3 style="color: #1a1a2e; font-weight: 800; font-size: 1.45rem; margin-bottom: 12px;">
            {{popup_title}}
        </h3>

        <p style="color: #555; font-size: 1rem; line-height: 1.6; margin-bottom: 24px;">
            {{popup_message}}
        </p>

        <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
            <a href="{{continue_url}}"
               class="btn btn-primary font-weight-bold"
               style="border-radius: 10px; padding: 10px 28px; font-size: 1rem;
                      background: linear-gradient(135deg,#667eea,#764ba2);
                      border: none; box-shadow: 0 4px 15px rgba(102,126,234,0.4);">
                🚀 {{popup_next}}
            </a>
            <button onclick="document.getElementById('ap-achievement-modal-overlay').style.display='none';"
                    class="btn btn-outline-secondary font-weight-bold"
                    style="border-radius:10px; padding:10px 24px; font-size:1rem;">
                Stay Here
            </button>
        </div>
    </div>
</div>

<style>
@keyframes apPopIn {
    from { opacity: 0; transform: scale(0.7) translateY(30px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
}
@keyframes apBadgeBounce {
    0%   { transform: scale(0) rotate(-20deg); opacity: 0; }
    70%  { transform: scale(1.15) rotate(5deg); opacity: 1; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
}
</style>

<script>
(function() {
    document.addEventListener('DOMContentLoaded', function() {
        var overlay = document.getElementById('ap-achievement-modal-overlay');
        if (overlay) {
            overlay.style.display = 'flex';
        }
    });
    document.addEventListener('click', function(e) {
        var overlay = document.getElementById('ap-achievement-modal-overlay');
        if (overlay && e.target === overlay) {
            overlay.style.display = 'none';
        }
    });
})();
</script>
{{/score_is_100}}
