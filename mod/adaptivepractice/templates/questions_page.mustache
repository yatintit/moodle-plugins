{{!
    Questions management template for Adaptive Practice
}}
<div class="mod_adaptivepractice_questions">
    <div class="tertiary-navigation mb-3">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h3 font-weight-bold text-dark mb-0">Manage Question Bank</h2>
            <a href="view.php?id={{id}}" class="btn btn-light border px-4" style="border-radius: 8px;">
                <i class="fa fa-arrow-left mr-1"></i> Back to Practice
            </a>
        </div>
    </div>

    {{#has_attempts}}
    <div class="alert alert-danger shadow-sm mb-4">
        <i class="fa fa-exclamation-triangle mr-2"></i>
        <strong>Cannot Edit Questions:</strong> You cannot change question settings or difficulty tiers because there are already student attempts for this activity. You must <a href="report.php?id={{id}}" class="alert-link">delete all student attempts</a> first before modifying these settings.
    </div>
    {{/has_attempts}}

    <div class="row">
        <div class="col-md-6">
            <div class="d-flex gap-2 mb-3">
                <a href="{{backurl}}" class="btn btn-secondary btn-sm">← {{#str}}back, mod_adaptivepractice{{/str}}</a>
                <a href="{{qbankurl}}" class="btn btn-outline-secondary btn-sm" target="_blank">{{#str}}questionbank, question{{/str}}</a>
            </div>
        </div>
        <div class="col-md-6 text-right">
             <form method="get" action="attempt.php" style="display:inline;">
                <input type="hidden" name="id" value="{{id}}">
                <button type="submit" class="btn btn-success btn-sm shadow-sm">🚀 Preview & Start Practice</button>
            </form>
        </div>
    </div>

    <h2 class="mb-4">{{#str}}questions, mod_adaptivepractice{{/str}}</h2>

    <div class="card shadow-sm mb-4 border-0" style="border-radius: 12px; border-top: 3px solid #10b981;">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    {{#has_selected_categories}}
                    <div class="mb-3">
                        <label class="font-weight-bold small text-uppercase text-muted">Currently Selected Categories</label>
                        <div class="list-group mb-2 shadow-sm" style="max-height: 200px; overflow-y: auto; border-radius: 8px; border: 1px solid #dee2e6;">
                            {{#selected_categories_list}}
                            <div class="list-group-item d-flex justify-content-between align-items-center py-2 bg-light border-0 border-bottom">
                                <span class="small font-weight-bold text-secondary">{{name}}</span>
                                <form method="post" action="" style="display:inline;" class="mb-0">
                                    <input type="hidden" name="id" value="{{id}}">
                                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                                    <input type="hidden" name="action" value="removecategory">
                                    <input type="hidden" name="remove_catid" value="{{value}}">
                                    <button type="submit" class="btn btn-link text-danger p-0 border-0" title="Remove" {{#has_attempts}}disabled{{/has_attempts}}>
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                            {{/selected_categories_list}}
                        </div>
                    </div>
                    {{/has_selected_categories}}

                    <form method="post" action="">
                        <label class="font-weight-bold small text-uppercase text-muted">Step 1: Select Question Categories</label>
                        <input type="hidden" name="id" value="{{id}}">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <input type="hidden" name="action" value="setcategory">

                        <div class="form-group mb-2">
                            <select name="categoryids[]" id="id_categoryid" class="form-control custom-select" multiple="multiple" size="8" style="border-radius: 8px;" {{#has_attempts}}disabled{{/has_attempts}}>
                                {{#catgroups}}
                                <optgroup label="{{name}}">
                                    {{#options}}
                                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                                    {{/options}}
                                </optgroup>
                                {{/catgroups}}
                            </select>
                        </div>
                        <div class="mb-3">
                            <details class="border rounded p-2 bg-light shadow-sm">
                                <summary class="btn btn-sm text-primary py-0" style="cursor: pointer;">
                                    <i class="fa fa-exchange mr-1"></i> Switch question bank (Current: {{current_bank_name}})
                                </summary>
                                <div id="ap_bank_switcher_container" class="mt-3">
                                    {{{bankswitcher_html}}}
                                </div>
                            </details>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block shadow-sm" {{#has_attempts}}disabled{{/has_attempts}}>Save Categories</button>
                        <p class="small text-muted mt-2 mb-0"><i class="fa fa-info-circle"></i> Ctrl+Click to select multiple.</p>
                    </form>
                </div>

                <div class="col-md-6 border-left">
                    <form method="post" action="">
                        <h5 class="card-title mb-3 font-weight-bold d-flex justify-content-between">
                            <span>Step 2: Get Random Questions</span>
                            {{#is_random_source}}
                            <span class="badge badge-success px-2 py-1" style="font-size: 0.7rem; vertical-align: middle;">ACTIVE MODE</span>
                            {{/is_random_source}}
                        </h5>
                        <input type="hidden" name="id" value="{{id}}">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <input type="hidden" name="action" value="addrandom">

                        <div class="row no-gutters mb-3">
                            <div class="col px-1">
                                <label class="small font-weight-bold text-success mb-1">EASY</label>
                                <input type="number" name="random_easy" value="{{random_easy}}" min="0" class="form-control form-control-sm text-center" {{#has_attempts}}disabled{{/has_attempts}}>
                            </div>
                            <div class="col px-1">
                                <label class="small font-weight-bold text-warning mb-1">MEDIUM</label>
                                <input type="number" name="random_medium" value="{{random_medium}}" min="0" class="form-control form-control-sm text-center" {{#has_attempts}}disabled{{/has_attempts}}>
                            </div>
                            <div class="col px-1">
                                <label class="small font-weight-bold text-danger mb-1">HARD</label>
                                <input type="number" name="random_hard" value="{{random_hard}}" min="0" class="form-control form-control-sm text-center" {{#has_attempts}}disabled{{/has_attempts}}>
                            </div>
                        </div>

                        <button type="submit" id="ap_autossign_btn" class="btn btn-info btn-block shadow-sm" {{#has_attempts}}disabled{{/has_attempts}}>
                            <i class="fa fa-bolt mr-1"></i> Auto-Assign Questions
                        </button>
                        <p class="small text-muted mt-2 mb-0">Randomly pulls unassigned questions from selected categories into tiers.</p>
                        <div id="ap_autoassign_warning" class="alert alert-warning mt-2 mb-0 py-2 px-3 d-none" style="border-radius:6px;font-size:0.875rem;">
                            <i class="fa fa-exclamation-triangle mr-1"></i>
                            <strong>No categories selected.</strong> Please select at least one category in <strong>Step 1</strong> and click <strong>Update Categories</strong> before auto-assigning questions.
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {{#has_categories}}
        <div class="mb-3">
            <p class="text-muted mb-0">
                <strong>{{num_categories}} categories</strong> selected — 
                {{#is_filtered}}
                    Showing <strong>{{num_questions}}</strong> of <strong>{{num_total}}</strong> questions.
                {{/is_filtered}}
                {{^is_filtered}}
                    <strong>{{num_total}}</strong> questions found.
                {{/is_filtered}}
            </p>
        </div>

        {{#has_questions}}
        <form method="post" action="">
            <input type="hidden" name="id" value="{{id}}">
            <input type="hidden" name="sesskey" value="{{sesskey}}">
            <input type="hidden" name="action" value="savetiers">

            <div class="card shadow-sm mb-4 border-0" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header bg-white py-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-center" style="gap: 15px;">
                        <h5 class="mb-0 font-weight-bold">
                            <span>Step 3: Assign Difficulty Tiers</span>
                            {{^is_random_source}}
                            <span class="badge badge-success px-2 py-1 ml-2" style="font-size: 0.7rem; vertical-align: middle;">ACTIVE MODE</span>
                            {{/is_random_source}}
                        </h5>
                        
                        <div class="d-flex align-items-center" style="gap: 15px;">
                            <!-- Real-time Search Input -->
                            <div class="input-group input-group-sm" style="max-width: 250px;">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-white border-right-0"><i class="fa fa-search text-muted"></i></span>
                                </div>
                                <input type="text" id="ap_question_search" class="form-control form-control-sm border-left-0" placeholder="Search questions..." style="border-radius: 0 5px 5px 0;">
                            </div>
                            
                            <div class="form-inline">
                                <span class="small text-muted mr-2">Show: </span>
                                <select onchange="window.location.href='?id={{id}}&filter='+this.value" class="form-control form-control-sm custom-select" style="border-radius: 5px;">
                                    {{#filteroptions}}
                                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                                    {{/filteroptions}}
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th width="40" class="text-center font-weight-bold">#</th>
                                    <th class="font-weight-bold">Question Name</th>
                                    <th class="font-weight-bold">Category</th>
                                    <th width="100" class="font-weight-bold text-center">Type</th>
                                    <th width="180" class="font-weight-bold">Difficulty Tier</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#questions}}
                                <tr>
                                    <td class="text-center align-middle text-muted small">{{index}}</td>
                                    <td class="align-middle">
                                        <div class="font-weight-bold">{{name}}</div>
                                    </td>
                                    <td class="align-middle small text-muted">
                                        {{category}}
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="badge badge-secondary">{{type}}</span>
                                    </td>
                                    <td class="align-middle">
                                        <select name="tier[{{id}}]" class="form-control form-control-sm custom-select" style="border-radius: 5px;" {{#has_attempts}}disabled{{/has_attempts}}>
                                            {{#tiers}}
                                            <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                                            {{/tiers}}
                                        </select>
                                    </td>
                                </tr>
                                {{/questions}}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
                    <div class="text-muted small">
                        🟢 Easy: <strong>{{counts.easy}}</strong> &nbsp;|&nbsp; 
                        🟡 Medium: <strong>{{counts.medium}}</strong> &nbsp;|&nbsp; 
                        🔴 Hard: <strong>{{counts.hard}}</strong> &nbsp;|&nbsp; 
                        Unassigned: <strong>{{counts.unassigned}}</strong> &nbsp;|&nbsp;
                        ❌ Excluded: <strong>{{counts.excluded}}</strong>
                    </div>
                    <button type="submit" class="btn btn-success px-5 font-weight-bold" style="border-radius: 8px;" {{#has_attempts}}disabled{{/has_attempts}}>💾 Save Tier Assignments</button>
                </div>
            </div>
        </form>
        {{/has_questions}}

        {{#has_no_questions}}
        <div class="alert alert-warning shadow-sm d-flex align-items-start" style="border-radius: 10px; border-left: 4px solid #f59e0b;">
            <i class="fa fa-exclamation-triangle fa-2x text-warning mr-3 mt-1"></i>
            <div>
                <strong>No questions found in the selected categories.</strong>
                <p class="mb-2 mt-1">The categories you selected do not currently contain any questions.</p>
                <p class="mb-0">
                    👉 Please <a href="{{qbankurl}}" target="_blank" class="font-weight-bold">open the Question Bank</a>
                    and add questions to your selected categories first, then return to this page.
                </p>
            </div>
        </div>
        {{/has_no_questions}}
    {{/has_categories}}

    {{#has_no_categories}}
    <div class="alert alert-info shadow-sm d-flex align-items-start" style="border-radius: 10px; border-left: 4px solid #3b82f6;">
        <i class="fa fa-info-circle fa-2x text-info mr-3 mt-1"></i>
        <div>
            <strong>No categories selected yet.</strong>
            <p class="mb-0 mt-1">
                Please select one or more question categories from <strong>Step 1</strong> on the left and click
                <strong>Update Categories</strong> to load your questions here.
            </p>
        </div>
    </div>
    {{/has_no_categories}}

</div>

{{#js}}
require(['jquery'], function($) {

    // Intercept bank switcher links.
    $('#ap_bank_switcher_container').on('click', '[data-newmodid]', function(e) {
        e.preventDefault();
        var newBankId = $(this).data('newmodid');
        window.location.href = 'questions.php?id={{id}}&bankid=' + newBankId;
    });
    
    // Autocomplete redirect if present.
    $('#ap_bank_switcher_container').on('change', '#searchbanks', function() {
        var newBankId = $(this).val();
        if (newBankId) {
            window.location.href = 'questions.php?id={{id}}&bankid=' + newBankId;
        }
    });

    // Client-side guard: Step 2 Auto-Assign — warn if no categories selected.
    var hasCats = {{#has_categories}}true{{/has_categories}}{{^has_categories}}false{{/has_categories}};
    $('#ap_autossign_btn').closest('form').on('submit', function(e) {
        if (!hasCats) {
            e.preventDefault();
            $('#ap_autoassign_warning').removeClass('d-none');
            $('html, body').animate({ scrollTop: $('#ap_autoassign_warning').offset().top - 100 }, 400);
            return false;
        }
    });

    // Step 3 client-side real-time question filter.
    $('#ap_question_search').on('keyup input', function() {
        var query = $(this).val().toLowerCase().trim();
        $('.table-hover tbody tr').each(function() {
            var qname = $(this).find('td:nth-child(2)').text().toLowerCase();
            var category = $(this).find('td:nth-child(3)').text().toLowerCase();
            if (qname.indexOf(query) !== -1 || category.indexOf(query) !== -1) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    });
});
{{/js}}
